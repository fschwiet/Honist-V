{
  "name": "honist-v",
  "version": "0.0.1",
  "description": "A Claude Code plugin",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "verify": "pnpm format:check && pnpm lint && pnpm lint:md",
    "lint": "eslint .",
    "lint:md": "markdownlint-cli2",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "markdownlint-cli2": "^0.23.1",
    "prettier": "^3.8.4"
  }
}
